# Permit.io Configuration
PERMIT_API_KEY=your_permit_api_key_here
PERMIT_PDP_URL=http://permit:7766
PDP_DEBUG=False

# Policy Service Configuration
AUTO_CREATE_ATTRIBUTES=true
ATTRIBUTE_PREFIX=attr_
REQUIRE_REGISTRATION=false
DECISION_CACHE_TTL=60
DECISION_CACHE_SIZE=1000
COMPONENT_CONFIG_PATH=./configs/components.json

# Permit.io Synchronization (Debounced Sync & Attribute Caching)
# Interval in seconds for syncing to Permit.io (0 = immediate sync)
PERMIT_SYNC_INTERVAL_SECONDS=30
# Path to the attribute cache file (persists across restarts)
PERMIT_ATTRIBUTE_CACHE_PATH=./configs/permit_attributes.json
# Enable/disable attribute caching (reduces duplicate API calls)
PERMIT_ENABLE_ATTRIBUTE_CACHING=true
# Pagination size for list_users() API calls
PERMIT_PAGINATION_PER_PAGE=100
# Default Permit.io tenant ID
PERMIT_DEFAULT_TENANT_ID=default

# ML Model Configuration
# Default role for ML models
ML_DEFAULT_ROLE=ML
# Prefix for ML model component IDs
ML_COMPONENT_PREFIX=ml-

# API Configuration
API_HOST=0.0.0.0
API_PORT=8788

# Logging
LOG_LEVEL=INFO

# Transformer Configuration
TRANSFORMER_CONFIG_PATH=./configs/transformers.json

# Client SDK Configuration (for components using the client)
POLICY_SERVICE_URL=http://policy-service:8788
POLICY_ENABLED=false
