# Permit.io Configuration
PERMIT_API_KEY=your_permit_api_key_here
PERMIT_PDP_URL=http://permit:7766
PDP_DEBUG=False

# Policy Service Configuration
AUTO_CREATE_ATTRIBUTES=true
REQUIRE_REGISTRATION=false
DECISION_CACHE_TTL=60
DECISION_CACHE_SIZE=1000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8788

# Logging
LOG_LEVEL=INFO

# Transformer Configuration
TRANSFORMER_CONFIG_PATH=./configs/transformers.json

# Client SDK Configuration (for components using the client)
POLICY_SERVICE_URL=http://policy-service:8788
POLICY_ENABLED=false
